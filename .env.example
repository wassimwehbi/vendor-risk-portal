# Vendor Risk Portal — environment configuration
#
# Local dev needs NONE of this (the app runs fully offline on built-in defaults).
# For a PRODUCTION / shared deployment, copy this file to `.env` in the project
# root (the real `.env` is git-ignored) and fill in the values:
#
#     cp .env.example .env
#
# Variables can also be supplied directly by your hosting platform's env settings.

# ---- Production basics (required in production) ----------------------------
NODE_ENV=production
# Strong random secret for session signing. REQUIRED in production (the server
# refuses to boot without it). Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret
# The SPA origin. Locks CORS and is where auth flows redirect back to.
CLIENT_ORIGIN=https://vendor-risk.example.com
# Public base URL of the API. Used to build OAuth callback + magic/invite links:
#   ${PUBLIC_URL}/api/auth/{google,microsoft}/callback
PUBLIC_URL=https://vendor-risk.example.com
# Server port (optional; defaults to 4100).
# PORT=4100
#
# AUTH_MODE: leave UNSET in production. Outside production it defaults to `dev`
# (passwordless Developer sign-in); the server refuses to boot if AUTH_MODE=dev
# while NODE_ENV=production.

# ---- Access control --------------------------------------------------------
# Global administrators (comma-separated). These emails get the cross-tenant
# admin flag the first time they sign in: they see every tenant and manage
# tenants, users, memberships and invitations.
ADMIN_EMAILS=wassim@wehbi.me
# Optional: restrict sign-in to specific email domains (comma-separated).
# Empty = allow any domain that authenticates.
# ALLOWED_EMAIL_DOMAINS=wehbi.me,example.com
#
# NOTE on roles: with multi-tenancy, a non-admin user who signs in has NO access
# until a global admin assigns them to a tenant with a role (Analyst / Submitter
# / Viewer) — via the Admin page or an invite link. DEFAULT_ROLE only seeds the
# legacy per-user role field and does not grant tenant access on its own.
# DEFAULT_ROLE=Viewer

# ---- AI analysis (optional) ------------------------------------------------
# Without a key the deterministic rule engine is used.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- SSO providers (optional) ----------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=common

# ---- Email magic links + invitations (optional) ----------------------------
# Without SMTP, magic-link / invite URLs are logged to the server console and an
# admin can still copy the invite link from the Admin page.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=no-reply@vendor-risk.example.com

# ---- Cloudflare R2 usage monitor (optional) --------------------------------
# Emails an alert (via the SMTP settings above) when R2 usage approaches or
# crosses the free-tier limits. Alert-only — it never changes R2 or the app.
# Inert unless BOTH CLOUDFLARE_API_TOKEN and R2_ACCOUNT_ID are set. R2_ACCOUNT_ID
# is already required by Litestream (see litestream.yml); reuse the same value.
#
# Create a Cloudflare API token with the "Account Analytics: Read" permission
# (this is NOT the same as the R2 S3 access keys used by Litestream).
# Set these two here to also run the opt-in live test locally — no secrets in any
# committed file:  npm --prefix server run test:live  (it self-skips without them).
# CLOUDFLARE_API_TOKEN=
# R2_ACCOUNT_ID=your-cloudflare-account-id
# Recipient for alerts (defaults to the first ADMIN_EMAILS entry).
# R2_ALERT_EMAIL=wassim@wehbi.me
# Warn threshold as a percent of any free-tier limit (default 80).
# R2_ALERT_WARN_PERCENT=80
# How often to check, in hours (default 12).
# R2_MONITOR_INTERVAL_HOURS=12
# Replica bucket name, shown in alert emails for context (default vrp-litestream).
# R2_MONITOR_BUCKET=vrp-litestream
# Set to false to disable the monitor entirely (default enabled when configured).
# R2_MONITOR_ENABLED=true

# ---- Experimentation platform (optional; spec 0015) ------------------------
# A/B experiments are defined in experiments/*.yml and assigned in the server. The
# vars below only gate the GitHub Pages portal's read + auth paths; the platform
# serves variants without any of them set.
#
# Bearer token the portal sends to read aggregate results
# (GET /api/experiments/:key/results). Unset => that endpoint returns 503.
# Generate one with:  openssl rand -base64 32
# EXPERIMENTS_READ_TOKEN=
# Origin of the GitHub Pages portal, added to the CORS allow-list so it can call the
# results + device-flow relay endpoints (e.g. https://wassimwehbi.github.io).
# EXPERIMENTS_PORTAL_ORIGIN=
# Public client_id of the GitHub OAuth app used by the portal's device-flow login.
# The server injects it into the /api/gh-device/* relay; unset => relay returns 503.
# GH_OAUTH_CLIENT_ID=
